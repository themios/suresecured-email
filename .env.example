# Copy this to .env and fill in your values

# Database (Railway provides this automatically)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Server
PORT=3000
NODE_ENV=production

# Your tracking server's public URL (Railway gives you this after deploy)
TRACKER_URL=https://your-app.railway.app

# Your Shopify store URL
SITE_URL=https://suresecured.com

# Cookie domain — allows cookie to work on suresecured.com from your tracker subdomain
COOKIE_DOMAIN=.suresecured.com

# Shopify webhook secret (from Shopify admin > Settings > Notifications > Webhooks)
SHOPIFY_WEBHOOK_SECRET=your_shopify_webhook_secret

# JWT secret — make this long and random (32+ characters)
JWT_SECRET=replace_with_random_string_at_least_32_chars

# First admin account (used by setup.js)
ADMIN_EMAIL=tim@suresecured.com
ADMIN_PASSWORD=choose_a_strong_password

# Gmail OAuth (from Google Cloud Console)
GMAIL_CLIENT_ID=your_client_id.apps.googleusercontent.com
GMAIL_CLIENT_SECRET=your_client_secret
GMAIL_REDIRECT_URI=https://your-app.railway.app/gmail/callback

# Cron secret — any random string, used to secure the send-sequences endpoint
CRON_SECRET=replace_with_random_string

# Phase 6 — security & integrations
UNSUBSCRIBE_HMAC_SECRET=replace_with_random_string
TOKEN_ENCRYPTION_KEY=32_byte_hex_key_for_oauth_encryption
CLIENT_API_KEY=server_to_server_key_for_shopify_flow
CALLRAIL_WEBHOOK_SECRET=your_callrail_webhook_secret
RETELL_WEBHOOK_SECRET=optional_fallback_if_signature_headers_differ
RETELL_API_KEY=your_retell_api_key
TELNYX_WEBHOOK_SECRET=shared_secret_for_telnyx_webhooks
TELNYX_PUBLIC_KEY=optional_ed25519_public_key_pem
ZEROBOUNCE_API_KEY=your_zerobounce_key  # OPTIONAL — not needed if list cleaned offline before CSV import
OPENROUTER_API_KEY=your_openrouter_key
APP_BASE_URL=https://your-app.railway.app
